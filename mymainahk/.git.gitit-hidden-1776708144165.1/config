[core]
	repositoryformatversion = 0
	filemode = false
	bare = false
	logallrefupdates = true
	symlinks = false
	ignorecase = true
	compression = 9
	preloadindex = true
	fscache = true
	longpaths = true
	bigFileThreshold = 1m
[remote "origin"]
	url = https://github.com/Michaelunkai/mymainahk.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[pack]
	threads = 0
	windowMemory = 256m
	packSizeLimit = 100m
[gc]
	auto = 0
[http]
	postBuffer = 524288000
	maxRequestBuffer = 524288000
[user]
	name = Michaelunkai
	email = Michaelunkai@users.noreply.github.com
